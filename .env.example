# Certificate Generator — Environment Variables
# Copy this file to .env and fill in your values.

# A strong random secret key for Flask sessions and CSRF.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=c0e5afccc008bc027ff589f88fb000bcdd2131c6ed827309e05cc39e615db2ff

# Set to 'true' to enable Flask debug mode (never in production!)
FLASK_DEBUG=false

# Upload and output directories (defaults are fine for most setups)
# UPLOAD_FOLDER=uploads
# OUTPUT_FOLDER=output
